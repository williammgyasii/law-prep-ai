generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress   Progress[]
  notes      Note[]
  weakAreas  WeakArea[]
  studyPlans StudyPlan[]
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int      @default(0)
  color       String   @default("#4f46e5")
  icon        String   @default("BookOpen")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resources Resource[]
  weakAreas WeakArea[]
}

enum ResourceType {
  video
  lesson
  drill
  practice_test
  article
}

enum Difficulty {
  easy
  medium
  hard
}

enum ProgressStatus {
  not_started
  in_progress
  completed
  review_later
}

model Resource {
  id               String       @id @default(cuid())
  title            String
  description      String       @default("")
  url              String       @default("")
  type             ResourceType @default(lesson)
  difficulty       Difficulty   @default(medium)
  estimatedMinutes Int          @default(30)
  moduleId         String
  tags             String[]     @default([])
  order            Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  module   Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress Progress[]
  notes    Note[]
}

model Progress {
  id               String         @id @default(cuid())
  userId           String
  resourceId       String
  status           ProgressStatus @default(not_started)
  completedAt      DateTime?
  confidenceScore  Int?
  timeSpentMinutes Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model Note {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  content    String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

model WeakArea {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String   @default("")
  confidenceScore Int      @default(1)
  moduleId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
}

model StudyPlan {
  id            String   @id @default(cuid())
  userId        String
  title         String
  examDate      DateTime?
  preferences   Json     @default("{}")
  generatedPlan Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
